{
  "name": "healspace-frontend",
  "version": "1.0.0",
  "description": "Backend API for HealSpace",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "vite",
    "start": "node src/server.js",
    "test:api": "node scripts/test-api.js",
    "test:password-reset": "node scripts/test-password-reset.js",
    "test:email-verification": "node scripts/test-email-verification.js",
    "test:user-search": "node scripts/test-user-search.js",
    "test:group-invitations": "node scripts/test-group-invitations.js",
    "test:sessions": "node scripts/test-advanced-sessions.js",
    "test:socket": "node scripts/test-socket-notifications.js",
    "test:socket:messages": "node scripts/test-socket-messages.js",
    "test:socket:group-invitations": "node scripts/test-socket-group-invitations.js",
    "test:secondary-auth": "npm run test:password-reset && npm run test:email-verification",
    "test:secondary": "npm run test:secondary-auth && npm run test:user-search && npm run test:group-invitations && npm run test:sessions",
    "test:realtime": "npm run test:socket && npm run test:socket:messages && npm run test:socket:group-invitations",
    "test:security": "node scripts/test-production-security.js",
    "test:docs": "node scripts/test-swagger-docs.js",
    "test:all": "npm run test:api && npm run test:secondary && npm run test:realtime && npm run test:security && npm run test:docs",
    "sessions:cleanup": "node scripts/cleanup-sessions.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "echo \"Frontend lint not configured yet\"",
    "test": "echo \"No tests yet\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:ps": "docker compose ps",
    "docker:test:api": "docker compose exec api npm run test:api",
    "docker:test:secondary": "docker compose exec api npm run test:secondary",
    "docker:test:realtime": "docker compose exec api npm run test:realtime",
    "docker:test:docs": "docker compose exec api npm run test:docs",
    "docker:test:all": "docker compose exec api npm run test:all",
    "docker:db:reset": "docker compose exec api npx prisma migrate reset --force",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "healspace",
    "node",
    "express",
    "prisma",
    "postgresql",
    "api",
    "socket.io",
    "realtime"
  ],
  "author": "Tihamy Tao Goulah",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@vitejs/plugin-react": "^6.0.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.24.0",
    "morgan": "^1.10.1",
    "multer": "2.2.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "vite": "^8.1.4",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.10.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": "true"
}
