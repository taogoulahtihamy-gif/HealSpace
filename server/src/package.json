{
  "name": "healspace-backend",
  "version": "1.0.0",
  "description": "Backend API for HealSpace",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test:api": "node scripts/test-api.js",
    "test:socket": "node scripts/test-socket-notifications.js",
    "test:socket:messages": "node scripts/test-socket-messages.js",
    "test:realtime": "npm run test:socket && npm run test:socket:messages",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "echo \"Lint not configured yet\"",
    "test": "echo \"No tests yet\"",
    "test:password-reset": "node scripts/test-password-reset.js",
    "test:email-verification": "node scripts/test-email-verification.js",
    "test:secondary-auth": "npm run test:password-reset && npm run test:email-verification",
    "test:docs": "node scripts/test-swagger-docs.js",
    "test:all": "npm run test:security && npm run test:api && npm run test:secondary && npm run test:realtime && npm run test:docs"
  },
  "keywords": [
    "healspace",
    "node",
    "express",
    "prisma",
    "postgresql",
    "api",
    "socket.io",
    "realtime"
  ],
  "author": "Tihamy Tao Goulah",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "2.2.0",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.0.14",
    "swagger-ui-express": "^5.0.1",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.10.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
