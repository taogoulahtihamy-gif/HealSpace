{
  "name": "healspace-backend",
  "version": "1.0.0",
  "description": "Backend API for HealSpace",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test:api": "node scripts/test-api.js",
    "test:password-reset": "node scripts/test-password-reset.js",
    "test:email-verification": "node scripts/test-email-verification.js",
    "test:user-search": "node scripts/test-user-search.js",
    "test:group-invitations": "node scripts/test-group-invitations.js",
    "test:sessions": "node scripts/test-advanced-sessions.js",
    "test:socket": "node scripts/test-socket-notifications.js",
    "test:socket:messages": "node scripts/test-socket-messages.js",
    "test:socket:group-invitations": "node scripts/test-socket-group-invitations.js",
    "test:secondary-auth": "npm run test:password-reset && npm run test:email-verification",
    "test:secondary": "npm run test:secondary-auth && npm run test:user-search && npm run test:group-invitations && npm run test:sessions",
    "test:realtime": "npm run test:socket && npm run test:socket:messages && npm run test:socket:group-invitations",
    "test:security": "node scripts/test-production-security.js",
    "test:docs": "node scripts/test-swagger-docs.js",
    "test:all": "npm run test:api && npm run test:secondary && npm run test:realtime && npm run test:security && npm run test:docs",
    "sessions:cleanup": "node scripts/cleanup-sessions.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint .",
    "test": "echo \"No tests yet\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality:config": "node scripts/quality-check.js",
    "quality:check": "npm run lint && npm run format:check && npm run quality:config",
    "sonar": "sonar-scanner",
    "render:build": "npm ci && npx prisma generate",
    "render:start": "sh scripts/render-start.sh",
    "render:migrate": "npx prisma migrate deploy",
    "render:health": "node scripts/render-health-check.js"
  },
  "keywords": [
    "healspace",
    "node",
    "express",
    "prisma",
    "postgresql",
    "api",
    "socket.io",
    "realtime"
  ],
  "author": "Tihamy Tao Goulah",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "2.2.0",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.9.5",
    "prisma": "^6.10.1",
    "sonar-scanner": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
