NODE_ENV=production
PORT=10000

# Render web service URL après déploiement.
CLIENT_URL=https://your-frontend-domain.example
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example,https://your-render-api.onrender.com
TRUST_PROXY_HOPS=1

# Render Postgres Internal Database URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# À créer comme secret Render. Utiliser une valeur longue et aléatoire.
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

SESSION_ACTIVITY_TOUCH_MINUTES=5
SESSION_CLEANUP_RETENTION_DAYS=30

JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=256kb

RATE_LIMIT_ENABLED=true

GLOBAL_RATE_LIMIT_WINDOW_MINUTES=15
GLOBAL_RATE_LIMIT_MAX=1000

LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX=5

REGISTER_RATE_LIMIT_WINDOW_MINUTES=60
REGISTER_RATE_LIMIT_MAX=20

REFRESH_RATE_LIMIT_WINDOW_MINUTES=15
REFRESH_RATE_LIMIT_MAX=30

PASSWORD_RESET_RATE_LIMIT_WINDOW_MINUTES=15
PASSWORD_RESET_RATE_LIMIT_MAX=10

EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_MINUTES=60
EMAIL_VERIFICATION_RATE_LIMIT_MAX=10

MEDIA_UPLOAD_RATE_LIMIT_WINDOW_MINUTES=60
MEDIA_UPLOAD_RATE_LIMIT_MAX=30

MAIL_TRANSPORT=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_NAME=HealSpace
MAIL_FROM_ADDRESS=no-reply@your-domain.example

PASSWORD_RESET_URL=https://your-frontend-domain.example/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

EMAIL_VERIFICATION_URL=https://your-frontend-domain.example/verify-email
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

GROUP_INVITATION_TTL_HOURS=168

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_MEDIA_FOLDER=healspace/media
RUN_CLOUDINARY_TESTS=false

LOG_LEVEL=info
EXPOSE_ERROR_DETAILS=false
SECURITY_TEST_MODE=false

PRISMA_GENERATE_ON_START=false
PRISMA_MIGRATE_ON_START=false
WAIT_FOR_DATABASE=false
DATABASE_WAIT_TIMEOUT_MS=60000
